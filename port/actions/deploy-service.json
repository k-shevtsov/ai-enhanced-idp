{
  "identifier": "deploy_service",
  "title": "🚀 Deploy Service",
  "icon": "Deployment",
  "description": "Deploy a service to Kubernetes cluster",
  "trigger": {
    "type": "self-service",
    "operation": "CREATE",
    "userInputs": {
      "properties": {
        "service_name": {
          "type": "string",
          "title": "Service Name"
        },
        "image": {
          "type": "string",
          "title": "Docker Image",
          "default": "nginx:1.25"
        },
        "replicas": {
          "type": "number",
          "title": "Replicas",
          "default": 2,
          "minimum": 1,
          "maximum": 5
        },
        "namespace": {
          "type": "string",
          "title": "Namespace",
          "default": "default",
          "enum": [
            "default",
            "staging",
            "production"
          ]
        },
        "environment": {
          "type": "string",
          "title": "Environment",
          "default": "dev",
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        }
      },
      "required": [
        "service_name",
        "image"
      ]
    }
  },
  "invocationMethod": {
    "type": "GITHUB",
    "org": "k-shevtsov",
    "repo": "mini-idp",
    "workflow": "deploy-service.yml",
    "workflowInputs": {
      "service_name": "{{ .inputs.service_name }}",
      "image": "{{ .inputs.image }}",
      "replicas": "{{ .inputs.replicas }}",
      "namespace": "{{ .inputs.namespace }}",
      "environment": "{{ .inputs.environment }}",
      "port_run_id": "{{ .run.id }}"
    },
    "reportWorkflowStatus": true
  }
}
